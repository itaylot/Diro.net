# ─── דירונט — environment secrets ────────────────────────────────
# Copy this file to ".env" and fill in real values on your server.
# Anything set here OVERRIDES the values in settings.json.
# Never commit the real .env file.

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=

# Your Telegram chat id (the bot tells you on /start)
TELEGRAM_CHAT_ID=

# Optional: port for the web dashboard (default 5050)
PORT=5050

# ─── Public deployment (Caddy: HTTPS + login) ──────────────────
# Your domain (DuckDNS subdomain or a real domain pointing at the server IP)
SITE_ADDRESS=diro.duckdns.org

# bcrypt password hashes for the two login users.
# Generate each ON THE SERVER and paste the output here:
#   docker run --rm caddy caddy hash-password --plaintext 'your-password'
# These are PLACEHOLDERS — replace them. Never commit real hashes.
ITAY_HASH=REPLACE_WITH_BCRYPT_HASH_FROM_SERVER
NETA_HASH=REPLACE_WITH_BCRYPT_HASH_FROM_SERVER

# ─── Facebook split: server vs home PC ─────────────────────────
# Facebook blocks datacenter IPs, so the FB agent runs on the home PC and
# pushes results to the server. Use the SAME INGEST_TOKEN on both machines.
#
# ON THE SERVER .env:
#   DISABLE_FACEBOOK=1
#   INGEST_TOKEN=<shared-secret>
#
# ON THE HOME PC .env:
#   INGEST_URL=https://dironet.duckdns.org/api/ingest
#   INGEST_TOKEN=<same-shared-secret>
DISABLE_FACEBOOK=
INGEST_URL=
INGEST_TOKEN=

